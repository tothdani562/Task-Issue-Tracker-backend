{
  "info": {
    "_postman_id": "iter6-auth-hardening-collection",
    "name": "Iteration 6 - Auth Hardening",
    "description": "Collection for testing iteration 6: refresh token flow, logout token revocation, auth hardening headers, and login rate limiting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Flow",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Register status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Register returns user and token pair', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('accessToken');",
                  "  pm.expect(body).to.have.property('refreshToken');",
                  "  pm.expect(body).to.have.property('user');",
                  "  pm.expect(body.user).to.have.property('id');",
                  "  pm.expect(body.user).to.have.property('email');",
                  "  pm.environment.set('user_id', body.user.id);",
                  "  pm.environment.set('user_email', body.user.email);",
                  "  pm.environment.set('access_token', body.accessToken);",
                  "  pm.environment.set('refresh_token', body.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"iter6_{{$timestamp}}@example.com\",\"password\":\"Password123\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Me with Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Me status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Me response contains current user', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('user');",
                  "  pm.expect(body.user).to.have.property('userId', pm.environment.get('user_id'));",
                  "  pm.expect(body.user).to.have.property('email', pm.environment.get('user_email'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Refresh status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Refresh returns new token pair', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('accessToken');",
                  "  pm.expect(body).to.have.property('refreshToken');",
                  "  pm.expect(body.user).to.have.property('id', pm.environment.get('user_id'));",
                  "  pm.expect(body.user).to.have.property('email', pm.environment.get('user_email'));",
                  "  pm.environment.set('access_token', body.accessToken);",
                  "  pm.environment.set('refresh_token', body.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refresh_token}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          }
        },
        {
          "name": "Security Headers on Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Me status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Helmet header exists', function () {",
                  "  const frame = pm.response.headers.get('x-frame-options');",
                  "  const contentTypeOptions = pm.response.headers.get('x-content-type-options');",
                  "  pm.expect(Boolean(frame) || Boolean(contentTypeOptions)).to.equal(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Logout status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Logout returns success', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('success', true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/logout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        },
        {
          "name": "Refresh After Logout (Should Fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Refresh after logout is unauthorized', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refresh_token}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Login returns token pair', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('accessToken');",
                  "  pm.expect(body).to.have.property('refreshToken');",
                  "  pm.environment.set('access_token', body.accessToken);",
                  "  pm.environment.set('refresh_token', body.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{user_email}}\",\"password\":\"{{user_password}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Invalid Refresh Token (Should Fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Invalid refresh token returns 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{invalid_refresh_token}}\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Rate Limiting",
      "item": [
        {
          "name": "Rate Limit - Init Counter",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.environment.set('rate_limit_counter', '0');",
                  "pm.execution.setNextRequest('Rate Limit - Login Attempt');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "Rate Limit - Login Attempt",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const current = Number(pm.environment.get('rate_limit_counter') || '0');",
                  "const next = current + 1;",
                  "pm.environment.set('rate_limit_counter', String(next));",
                  "pm.test('Attempt status is 401 or 429', function () {",
                  "  pm.expect([401, 429]).to.include(pm.response.code);",
                  "});",
                  "if (next < 6) {",
                  "  pm.execution.setNextRequest('Rate Limit - Login Attempt');",
                  "} else {",
                  "  pm.test('6th login attempt is throttled', function () {",
                  "    pm.expect(pm.response.code).to.equal(429);",
                  "  });",
                  "  pm.execution.setNextRequest(null);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{rate_limit_email}}\",\"password\":\"WrongPassword123\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "if (!pm.environment.get('rate_limit_email')) {",
          "  pm.environment.set('rate_limit_email', `rate_limit_${Date.now()}@example.com`);",
          "}"
        ]
      }
    }
  ]
}
