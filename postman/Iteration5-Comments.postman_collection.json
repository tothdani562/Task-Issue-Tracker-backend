      "name": "Auth",
      "item": [
        {
          "name": "Register User 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const response = pm.response.json();",
                  "  pm.environment.set('user1_id', response.user.id);",
                  "  pm.environment.set('user1_email', response.user.email);",
                  "  pm.environment.set('user1_token', response.accessToken);",
                  "  pm.test('User 1 registered successfully', () => {",
                  "    pm.expect(response.user.email).to.include('user1');",
                  "  });",
                  "} else {",
                  "  pm.test('Register User 1 failed', () => {",
                  "    pm.expect(pm.response.code).to.equal(201);",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"user1_{{$timestamp}}@example.com\",\"password\":\"Password123\"}"
