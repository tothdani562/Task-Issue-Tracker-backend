                  "pm.test('All returned tasks are HIGH priority', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "  pm.expect(jsonData.data.items).to.be.an('array');",
                  "  jsonData.data.items.forEach(function (task) {",
                  "    pm.expect(task.priority).to.equal('HIGH');",
                  "  });",
