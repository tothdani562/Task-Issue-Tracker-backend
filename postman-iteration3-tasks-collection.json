                  "  pm.expect(jsonData.user.id).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('memberToken', jsonData.accessToken);",
                  "  pm.environment.set('memberUserId', jsonData.user.id);",
                  "});"
