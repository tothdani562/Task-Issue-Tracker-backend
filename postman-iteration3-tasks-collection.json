        {
          "name": "14 List tasks page=1 limit=2",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Pagination meta for page 1 limit 2 is valid', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "  pm.expect(jsonData.data.meta.page).to.equal(1);",
                  "  pm.expect(jsonData.data.meta.limit).to.equal(2);",
                  "  pm.expect(jsonData.data.items.length).to.be.at.most(2);",
                  "  pm.expect(jsonData.data.meta.total).to.be.a('number');",
                  "  pm.expect(jsonData.data.meta.hasNext).to.be.a('boolean');",
                  "});"
                ]
