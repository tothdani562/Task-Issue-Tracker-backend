    {
      "name": "01 Task CRUD",
      "item": [
        {
          "name": "05 Create task #1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Task #1 is created and saved', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "  pm.expect(jsonData.data.id).to.be.a('string').and.not.empty;",
                  "  pm.expect(jsonData.data.status).to.equal('TODO');",
                  "  pm.expect(jsonData.data.priority).to.equal('HIGH');",
                  "  pm.environment.set('taskId', jsonData.data.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ownerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Iteration 3 - Task 1\",\n  \"description\": \"Primary task for CRUD checks\",\n  \"status\": \"TODO\",\n  \"priority\": \"HIGH\",\n  \"assignedUserId\": \"{{memberUserId}}\"\n}"
            },
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks"
          }
        },
        {
          "name": "06 Create task #2",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Task #2 is created and saved', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "  pm.expect(jsonData.data.id).to.be.a('string').and.not.empty;",
                  "  pm.expect(jsonData.data.status).to.equal('IN_PROGRESS');",
                  "  pm.expect(jsonData.data.priority).to.equal('LOW');",
                  "  pm.environment.set('task2Id', jsonData.data.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ownerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Iteration 3 - Task 2\",\n  \"description\": \"Secondary task for filter and pagination checks\",\n  \"status\": \"IN_PROGRESS\",\n  \"priority\": \"LOW\",\n  \"assignedUserId\": \"{{ownerUserId}}\"\n}"
            },
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks"
          }
        },
        {
          "name": "07 List tasks (basic)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns items and pagination meta', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "  pm.expect(jsonData.data.items).to.be.an('array');",
                  "  pm.expect(jsonData.data.meta).to.be.an('object');",
                  "  pm.expect(jsonData.data.meta).to.have.property('total');",
                  "  pm.expect(jsonData.data.meta).to.have.property('page');",
                  "  pm.expect(jsonData.data.meta).to.have.property('limit');",
                  "  pm.expect(jsonData.data.meta).to.have.property('hasNext');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ownerToken}}"
              }
            ],
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks"
          }
        },
        {
          "name": "08 Get task by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Task ID matches requested ID', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "  pm.expect(jsonData.data.id).to.equal(pm.environment.get('taskId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ownerToken}}"
              }
            ],
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}"
          }
        },
        {
          "name": "09 Update task #1",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Task status is updated to DONE', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "  pm.expect(jsonData.data.id).to.equal(pm.environment.get('taskId'));",
                  "  pm.expect(jsonData.data.status).to.equal('DONE');",
                  "  pm.expect(jsonData.data.priority).to.equal('HIGH');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ownerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DONE\",\n  \"priority\": \"HIGH\"\n}"
            },
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}"
          }
        }
      ]
    },
    {
      "name": "02 Filters",
      "item": [
        {
          "name": "10 Filter by status=DONE",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('All returned tasks are DONE', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "  pm.expect(jsonData.data.items).to.be.an('array');",
                  "  jsonData.data.items.forEach(function (task) {",
                  "    pm.expect(task.status).to.equal('DONE');",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ownerToken}}"
              }
            ],
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks?status=DONE"
          }
        },
        {
          "name": "11 Filter by priority=HIGH",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
