          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ownerToken}}"
              }
            ],
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks?priority=HIGH"
          }
        },
        {
          "name": "12 Filter by assigneeId=memberUserId",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('All returned tasks are assigned to member', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.success).to.equal(true);",
                  "  pm.expect(jsonData.data.items).to.be.an('array');",
