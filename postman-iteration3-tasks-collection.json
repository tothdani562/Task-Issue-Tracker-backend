    "name": "Nest-Prisma Iteration 3 - Tasks (CRUD, Filter, Pagination)",
    "description": "Standalone test flow for iteration 3. Includes setup (owner/member/project) and task CRUD + filters + pagination checks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
