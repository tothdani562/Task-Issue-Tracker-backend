  "item": [
    {
      "name": "00 Setup",
      "item": [
        {
          "name": "01 Register owner",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('ownerEmail', `owner_${Date.now()}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Owner token and user ID are saved', function () {",
                  "  const jsonData = pm.response.json();",
                  "  pm.expect(jsonData.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(jsonData.user.id).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('ownerToken', jsonData.accessToken);",
                  "  pm.environment.set('ownerUserId', jsonData.user.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
